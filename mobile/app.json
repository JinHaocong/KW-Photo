{
  "expo": {
    "name": "KW Photo",
    "slug": "kw-photo-mobile",
    "version": "0.1.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "cloud.kerwin.kwphoto.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "infuse"
        ]
      }
    },
    "android": {
      "package": "cloud.kerwin.kwphoto.mobile"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      "expo-video",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "319eea44-bdcf-4369-aa59-6817e31232b5"
      }
    }
  }
}
